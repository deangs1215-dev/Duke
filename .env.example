ENQUIRY_TO_EMAIL=enquiries@dukegs.com

# turboSMTP or another SMTP provider.
SMTP_HOST=pro.turbo-smtp.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM_EMAIL=website@dukegs.com

# Optional fallback. Used only when SMTP_HOST is not configured.
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=website@dukegs.com
